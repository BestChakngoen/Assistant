rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Support path: /users/{uid}/...
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      
      match /trades/{tradeId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      match /meta/summary {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      match /data/{dataDoc} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      match /health/{healthDoc} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Support path: /artifacts/{appId}/users/{uid}/...
    match /artifacts/{appId}/users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      
      match /trades/{tradeId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      match /meta/summary {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      match /data/{dataDoc} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      match /health/{healthDoc} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
